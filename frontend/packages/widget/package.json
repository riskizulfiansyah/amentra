{
  "name": "@amentra/widget",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build:css": "postcss src/tailwind.css -o src/styles.css && node scripts/generate-css-ts.mjs",
    "build": "pnpm build:css && tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist src/styles.css src/styles.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "lit": "^3.2.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  }
}
